# Will Wright - Swapper Encryptor

plaintext = input("Enter a phrase to encrypt (Swapper Method): ")

length = len(plaintext)

# Prepare ciphertext list with empty slots
ciphertext = [None] * length
positions = []

print("\n--- Character Placement ---")
print("You will choose where each character goes in the encrypted message.\n")

for character in plaintext:
    # Find open positions
    open_slots = [i for i, x in enumerate(ciphertext) if x is None]
    valid_choice = False

    while not valid_choice:
        print(f"Available positions: {open_slots}")
        try:
            new_position = int(input(f"Where should '{character}' go? Enter a position: "))
            if new_position in open_slots:
                ciphertext[new_position] = character
                positions.append(new_position)
                valid_choice = True
            else:
                print("Invalid choice — pick one of the open positions.\n")
        except ValueError:
            print("Please enter a valid number.\n")

# Convert list to string
ciphertext = ''.join(ciphertext)

print("\n--- Encryption Complete ---")
print(f"Original character positions (in order): {positions}")
print(f"Ciphertext: {ciphertext}")

