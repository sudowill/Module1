    # Will Wright - Custom Password Generator
import string
import secrets
import random

# Character pools
UPPER = string.ascii_uppercase
LOWER = string.ascii_lowercase
DIGITS = string.digits
SPECIAL = string.punctuation

print("\n--- Custom Secure Password Generator ---")

# Get user choices
num_upper = int(input("How many UPPERCASE letters?: "))
num_lower = int(input("How many lowercase letters?: "))
num_digits = int(input("How many digits?: "))
num_special = int(input("How many special characters?: "))

password_chars = []

# Add chosen characters
for _ in range(num_upper):
    password_chars.append(secrets.choice(UPPER))

for _ in range(num_lower):
    password_chars.append(secrets.choice(LOWER))

for _ in range(num_digits):
    password_chars.append(secrets.choice(DIGITS))

for _ in range(num_special):
    password_chars.append(secrets.choice(SPECIAL))

# Securely shuffle the final password
random.SystemRandom().shuffle(password_chars)

# Convert list to string
password = ''.join(password_chars)

print("\nYour secure password:")
print(password)
