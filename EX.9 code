# Will Wright - URL-safe Link Generator
import secrets
import string

def generate_token(length: int = 12) -> str:
    """Generate a URL-safe token of given length."""
    alphabet = string.ascii_letters + string.digits  # URL-safe characters
    return ''.join(secrets.choice(alphabet) for _ in range(length))

def main():
    base_url = "https://teameffort.work/"
    extension = ".png"   # You can change this to anything you want

    num_links = 100
    token_length = 12    # Length of random part

    print(f"Generating {num_links} URL-safe links:\n")

    for _ in range(num_links):
        token = generate_token(token_length)
        link = f"{base_url}{token}{extension}"
        print(link)

if __name__ == "__main__":
    main()

# Will Wright - SHA256 File Verification
import hashlib

def sha256_of_file(filename):
    """Return SHA256 hash of a file in hex format."""
    sha256 = hashlib.sha256()
    try:
        with open(filename, "rb") as f:
            for block in iter(lambda: f.read(4096), b""):
                sha256.update(block)
        return sha256.hexdigest()
    except FileNotFoundError:
        print(f"Error: File '{filename}' not found.")
        return None

