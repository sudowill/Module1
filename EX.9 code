# Splitter Cipher - ENCRYPTOR

# Ask for a phrase
plaintext = input("Enter a phrase to encrypt: ")

length = len(plaintext)

# Validate phrase length
if length < 2:
    print("Phrase must be at least 2 characters long.")
    exit()

# Ask for split position
prompt = (
    f"After how many characters should the split happen?\n"
    f"Enter a number between 1 and {length - 1}: "
)

while True:
    try:
        splitter = int(input(prompt))
        if 1 <= splitter <= length - 1:
            break
        else:
            print(f"Please enter a number between 1 and {length - 1}.")
    except ValueError:
        print("Please enter a valid number.")

# Perform encryption
ciphertext = plaintext[splitter:] + plaintext[:splitter]

print("\nEncrypted phrase:")
print(ciphertext)


# Splitter Cipher - DECRYPTOR

ciphertext = input("Enter the ciphertext to decrypt: ")

length = len(ciphertext)

if length < 2:
    print("Ciphertext must be at least 2 characters long.")
